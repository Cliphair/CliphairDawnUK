    "e2f1cba5-450b-4f18-b7f7-68b2979b08bd": {
      "type": "bridal_dropdown",
      "blocks": {
        "963cb829-5abc-430b-aa41-c9999a9a5666": {
          "type": "item",
          "settings": {
            "title": "<h3>How many times can I enter? </h3>",
            "body": "<p>There is no limit on the number of entries you can submit. You can also enter across multiple categories — just make sure you state which category each entry applies to in your caption. </p>"
          }
        },
        "37e8c7f1-722f-4702-bbce-9e8b581dae7a": {
          "type": "item",
          "settings": {
            "title": "<h3>Can I enter if I am outside the UK? </h3>",
            "body": "<p>Absolutely — the competition is open to entrants worldwide. There are no country restrictions.</p>"
          }
        },
        "5bbe76b3-da75-4df7-93af-847a7165a945": {
          "type": "item",
          "settings": {
            "title": "<h3>Do I have to use Cliphair extensions? </h3>",
            "body": "<p>Yes. Cliphair extensions must be used and credited in every submission. Entries without Cliphair extensions will unfortunately not be considered.</p>"
          }
        },
        "e5e823f4-b94e-49c7-8e89-c86c4d1cdbc6": {
          "type": "item",
          "settings": {
            "title": "<h3>Can I enter if I’m not a professional stylist? </h3>",
            "body": "<p>Yes! The competition is open to qualified, training and student hairstylists as well as hair enthusiasts. All entries must be your own work. </p>"
          }
        },
        "item_pqcPy3": {
          "type": "item",
          "settings": {
            "title": "<h3>When does the competition open and close? </h3>",
            "body": "<p>The competition opens on 13th May 2026 and closes at 11:59pm BST on 10th June 2026. Any entries submitted after this time will unfortunately not be considered.</p>"
          }
        },
        "item_t9fXgc": {
          "type": "item",
          "settings": {
            "title": "<h3>When will the winners be announced? </h3>",
            "body": "<p>Winners will be announced on 19th June 2026 across our social media channels, email and website.</p>"
          }
        }
      },
