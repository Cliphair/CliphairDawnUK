        "heading_Wfz4Vi": {
          "type": "heading",
          "settings": {
            "heading": "How to Enter",
            "heading_size": "h1",
            "h1": false
          }
        },
        "text_LnwW9y": {
          "type": "text",
          "settings": {
            "text": "<ol><li>Create a stunning wedding hairstyle using Cliphair extensions</li><li>Photograph or film your look — keep it high quality </li><li>Post to Instagram or Facebook</li><li>Use the hashtag #CliphairWeddingAwards26 </li><li>State which category you are entering in your caption </li><li>Tag us @cliphairlimited </li></ol>",
            "read-more_text": ""
          }
        },
        "heading_JFBCJR": {
          "type": "heading",
          "settings": {
            "heading": "Some Ground Rules",
            "heading_size": "h2",
            "h1": false
          }
        },
        "text_tJLDJp": {
          "type": "text",
          "settings": {
            "text": "<ul><li>The competition will run from 13th May 2026 – 10th June 2026. Entries must be submitted before 11:59pm BST on 10th June</li><li>All hairstyles must be created on a real person, not a training mannequin</li><li>Cliphair extensions must be used and credited in every submission</li><li>Please ensure all entries are dated from 13th May 2026 onwards. Any entries uploaded before this will unfortunately not be considered</li><li>There is no limit on the number of entries you can submit</li><li>By entering the competition, you are granting Cliphair permission to use your submitted content for marketing purposes, including but not limited to our winners’ blog, email communications and social media channels </li></ul>",
            "read-more_text": ""
          }
        },
        "heading_RHGTDb": {
          "type": "heading",
          "settings": {
            "heading": "Who Can Enter?  ",
            "heading_size": "h2",
            "h1": false
          }
        },
        "text_G9iGQT": {
          "type": "text",
          "settings": {
            "text": "<p>Any qualified, training or student hairstylist — or hair enthusiast — worldwide is eligible to enter. All entries submitted must be your own work.</p>",
            "read-more_text": ""
          }
        }
      },
