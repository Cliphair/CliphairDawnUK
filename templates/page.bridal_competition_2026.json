    "bridal_dropdown_DCMaTp": {
      "type": "bridal_dropdown",
      "blocks": {
        "item_8thME7": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Bridal Look — Judges’ Choice</strong></h3>",
            "body": "<p>The best overall bridal hairstyle using Cliphair extensions, selected by our judges. Open to any hairstyle.</p><p><strong>Prize:</strong></p><ul><li>£600 cash prize</li><li>Ultimate Hair Kit (bundle worth £600) </li><li>A dedicated blog on our website</li><li>Featured on our social media channels </li><li>Cliphair Award Certificate & Digital Badge <br/><strong><br/>Judge: </strong>Kasia Fortuna @kasia_fortuna</li></ul>"
          }
        },
        "item_jDUTbY": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Bridal Look — People’s Choice</strong></h3>",
            "body": "<p>The best overall bridal hairstyle using Cliphair extensions, voted for by the Cliphair community.</p><p><strong>Prize:</strong></p><ul><li>£600 cash prize </li><li>Ultimate Hair Kit (bundle worth £600)</li><li>A dedicated blog on our website</li><li>Featured on our social media channels</li><li>Cliphair Award Certificate & Digital Badge <br/><strong><br/>Judge: </strong>Judged by the public</li></ul>"
          }
        },
        "item_gFqRVQ": {
          "type": "item",
          "disabled": true,
          "settings": {
            "title": "<h3><strong>Best Cliphair Look - People’s Choice</strong></h3>",
            "body": "<p>The best bridal look using Cliphair extensions selected by the public.</p><p><strong>Prize:</strong></p><ul><li>£300 cash prize</li><li>5000 Loyalty Points</li><li>Ultimate Hair Kit (bundle worth £250)</li><li>A dedicated blog on our website</li><li>Featured on our social media channels</li><li>Cliphair Award Certificate & Digital Badge</li></ul><p>Judged by the public</p>"
          }
        },
        "item_GWRYHN": {
          "type": "item",
          "disabled": true,
          "settings": {
            "title": "<h3><strong>Best Cliphair Look - Judges</strong></h3>",
            "body": "<p>The best bridal look using Cliphair extensions selected by our judges. </p><p><strong>Prize:</strong> </p><ul><li>£300 cash prize </li><li>5000 Loyalty Points  </li><li>Ultimate Hair Kit (bundle worth £250) </li><li>A mention in our winners' blog on our website  </li><li>Featured on our social media channels</li><li>Cliphair Award Certificate & Digital Badge  </li></ul><p><strong><br/>Judge: </strong>Zoe Webbe</p>"
          }
        },
        "item_nVwEew": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Hair Down</strong></h3>",
            "body": "<p>This category is for any bridal hairstyle where all hair is left fully down and flowing — including loose waves, curls, sleek straight styles and blow-dry looks. Hair should not be pinned, secured or tied at any point.</p><p><strong>Prize:</strong> </p><ul><li>£300 gift card</li><li>A mention in our winners’ blog on our website</li><li>Featured on our social media channels  </li></ul><p><br/><strong>Judge:</strong> Stacie Goodwin @staciegoodwinbridalhair</p>"
          }
        },
        "item_eH49hy": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Hair Up </strong></h3>",
            "body": "<p>This category is for any bridal hairstyle where all hair is fully pinned, secured or styled up and away from the shoulders — including updos, chignons, buns and twisted styles. No hair should be left loose or flowing. </p><p><strong>Prize: </strong></p><ul><li>£300 gift card</li><li>A mention in our winners’ blog on our website</li><li>Featured on our social media channels </li></ul><p><br/><strong>Judge:</strong> Paige Lauren @paigelauren_bridalhair</p>"
          }
        },
        "item_LcBBM4": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Half Up Half Down </strong></h3>",
            "body": "<p>This category is for any bridal hairstyle that combines elements of both up and down — where a portion of the hair is pinned or secured at the crown or back, while the remaining hair flows loosely. Includes twisted half-up styles and pinned crown looks. </p><p><strong>Prize:</strong></p><ul><li>£300 gift card </li><li>A mention in our winners’ blog on our website </li><li>Featured on our social media channels </li></ul><p><br/><strong>Judge:</strong> UlyanaAster @ulyana.aster</p>"
          }
        },
        "item_LqwfPT": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Braid</strong></h3>",
            "body": "<p>This category is for any bridal hairstyle where braiding is the primary technique — including fishtail braids, Dutch braids, French braids, boho braids and plaited updos. The braid must be the defining feature of the look.</p><p><strong>Prize:</strong></p><ul><li>£300 gift card </li><li>A mention in our winners’ blog on our website </li><li>Featured on our social media channels </li></ul><p><br/><strong>Judge:</strong> LizCooper @theartfulhairstylist</p>"
          }
        },
        "item_8Qkx7d": {
          "type": "item",
          "settings": {
            "title": "<h3><strong>Best Ponytail</strong></h3>",
            "body": "<p>This category is for any bridal hairstyle where the hair is gathered and secured into a ponytail — including high,lowand side ponytails. Ponytails can be sleek or textured,straightor wavy.</p><p><strong>Prize:</strong></p><ul><li>£300 gift card </li><li>A mention in our winners’ blog on our website </li><li>Featured on our social media channels </li></ul><p><br/><strong>Judge:</strong> NatashaChanel @natashachanelhair</p>"
          }
        },
        "item_aWKpPm": {
          "type": "item",
          "disabled": true,
          "settings": {
            "title": "<h3><strong>Best International Look</strong></h3>",
            "body": "<p>This category is for any hairstyle.</p><p><strong>Prize:</strong></p><ul><li>Gift card £150</li><li>A mention in our winners’ blog on our website</li><li>Featured on our social media channels</li></ul><p><br/><strong>Judge:</strong> Ulyana Aster</p>"
          }
        }
      },
