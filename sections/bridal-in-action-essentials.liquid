{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slider-custom.css' | asset_url | stylesheet_tag }}
{{ 'section-bridal-in-action-essentials.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign video_count = 0
  assign product_count = 0

  for block in section.blocks
    case block.type
      when 'video_card'
        assign video_count = video_count | plus: 1
      when 'product_card'
        assign product_count = product_count | plus: 1
    endcase
  endfor

  assign show_video_slider = false
  if video_count > 2
    assign show_video_slider = true
  endif

  assign show_mobile_video_slider = false
  if video_count > 1
    assign show_mobile_video_slider = true
  endif

  assign show_product_slider = false
  if product_count > 4
    assign show_product_slider = true
  endif

  assign show_compact_product_slider = false
  if product_count > 2
    assign show_compact_product_slider = true
  endif

  assign product_page_count = product_count | plus: 3 | divided_by: 4
  assign compact_product_page_count = product_count | plus: 1 | divided_by: 2
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    <section class="biae" aria-labelledby="BiaeHeading-{{ section.id }}">
      <h2 id="BiaeHeading-{{ section.id }}" class="visually-hidden">
        {{ section.settings.video_heading | default: section.settings.product_heading | escape }}
      </h2>

      <div class="biae__panel biae__panel--video">
        <div class="biae__panel-header">
          {%- if section.settings.video_heading != blank -%}
            <h3 class="biae__panel-title h3">{{ section.settings.video_heading | escape }}</h3>
          {%- endif -%}
          {%- if section.settings.video_intro != blank -%}
            <p class="biae__panel-intro">{{ section.settings.video_intro | escape }}</p>
          {%- endif -%}
        </div>

        {%- if video_count > 0 -%}
          <slider-component-custom
            class="biae__video-slider biae__video-slider--mobile medium-hide large-up-hide"
            data-visual="dots"
            data-loop="true"
          >
            <ul
              id="Slider-{{ section.id }}-videos-mobile"
              class="biae__video-pages biae__video-pages--mobile{% if show_mobile_video_slider %} slider slider--everywhere{% endif %}"
              role="list"
              aria-label="{{ section.settings.video_heading | default: 'In Action videos' | escape }}"
            >
              {%- for block in section.blocks -%}
                {%- if block.type == 'video_card' -%}
                  <li
                    id="Slide-{{ section.id }}-videos-mobile-{{ forloop.index }}"
                    class="biae__video-page custom__slide{% if show_mobile_video_slider %} slider__slide{% endif %}"
                  >
                    {%- render 'bridal-in-action-video-card',
                      block: block,
                      video_heading: section.settings.video_heading,
                      image_sizes: 'calc((100vw - 3.72rem) / 1.4)'
                    -%}
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>

            {%- if section.settings.social_link_label != blank -%}
              <div class="biae__panel-footer">
                <a
                  {% if section.settings.social_link != blank %}
                    href="{{ section.settings.social_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                  class="biae__footer-link"
                >
                  {{ section.settings.social_link_label | escape }}
                </a>
              </div>
            {%- endif -%}
          </slider-component-custom>

          <slider-component-custom
            class="biae__video-slider biae__video-slider--desktop small-hide"
            data-visual="dots"
            data-loop="true"
          >
            <ul
              id="Slider-{{ section.id }}-videos-desktop"
              class="biae__video-pages biae__video-pages--desktop{% if show_video_slider %} slider slider--everywhere{% endif %}"
              role="list"
              aria-label="{{ section.settings.video_heading | default: 'In Action videos' | escape }}"
            >
              {%- assign rendered_video_count = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'video_card' -%}
                  {%- assign video_modulo = rendered_video_count | modulo: 2 -%}
                  {%- if video_modulo == 0 -%}
                    <li
                      id="Slide-{{ section.id }}-videos-desktop-{{ rendered_video_count | divided_by: 2 | floor | plus: 1 }}"
                      class="biae__video-page custom__slide{% if show_video_slider %} slider__slide{% endif %}"
                    >
                      <div class="biae__video-card-grid">
                  {%- endif -%}

                  {%- render 'bridal-in-action-video-card',
                    block: block,
                    video_heading: section.settings.video_heading,
                    image_sizes: 'calc((100vw - 4.8rem) / 2)'
                  -%}

                  {%- assign rendered_video_count = rendered_video_count | plus: 1 -%}
                  {%- assign close_video_page = rendered_video_count | modulo: 2 -%}
                  {%- if close_video_page == 0 or rendered_video_count == video_count -%}
                    </div>
                    </li>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </ul>

            {%- if show_video_slider -%}
              <div class="biae__video-slider-controls no-js-hidden small-hide medium-hide">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>
                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>
              </div>
            {%- endif -%}

            {%- if section.settings.social_link_label != blank or show_video_slider -%}
              <div class="biae__panel-footer{% if show_video_slider %} biae__panel-footer--with-dots{% endif %}">
                {%- if section.settings.social_link_label != blank -%}
                  <a
                    {% if section.settings.social_link != blank %}
                      href="{{ section.settings.social_link }}"
                    {% else %}
                      role="link" aria-disabled="true"
                    {% endif %}
                    class="biae__footer-link"
                  >
                    {{ section.settings.social_link_label | escape }}
                  </a>
                {%- endif -%}

                {%- if show_video_slider -%}
                  <div class="slider-counter slider-counter--dots biae__video-slider-dots small-hide medium-hide">
                    <div class="slideshow__control-wrapper"></div>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}
          </slider-component-custom>
        {%- else -%}
          <div class="biae__empty-state">Add video blocks to populate this panel.</div>
          {%- if section.settings.social_link_label != blank -%}
            <div class="biae__panel-footer">
              <a
                {% if section.settings.social_link != blank %}
                  href="{{ section.settings.social_link }}"
                {% else %}
                  role="link" aria-disabled="true"
                {% endif %}
                class="biae__footer-link"
              >
                {{ section.settings.social_link_label | escape }}
              </a>
            </div>
          {%- endif -%}
        {%- endif -%}
      </div>

      <div class="biae__panel biae__panel--products">
        <div class="biae__panel-header">
          {%- if section.settings.product_heading != blank -%}
            <h3 class="biae__panel-title h3">{{ section.settings.product_heading | escape }}</h3>
          {%- endif -%}
          {%- if section.settings.product_intro != blank -%}
            <p class="biae__panel-intro">{{ section.settings.product_intro | escape }}</p>
          {%- endif -%}
        </div>

        {%- if product_count > 0 -%}
          <slider-component class="biae__product-slider biae__product-slider--compact large-up-hide">
            <ul
              id="Slider-{{ section.id }}-products-compact"
              class="biae__product-pages biae__product-pages--compact{% if show_compact_product_slider %} slider slider--everywhere{% endif %}"
              role="list"
              aria-label="{{ section.settings.product_heading | default: 'Bridal Hair Essentials' | escape }}"
            >
              {%- assign rendered_compact_product_count = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'product_card' -%}
                  {%- assign compact_product_modulo = rendered_compact_product_count | modulo: 2 -%}
                  {%- if compact_product_modulo == 0 -%}
                    <li
                      id="Slide-{{ section.id }}-products-compact-{{ rendered_compact_product_count | divided_by: 2 | floor | plus: 1 }}"
                      class="biae__product-page custom__slide{% if show_compact_product_slider %} slider__slide{% endif %}"
                    >
                      <div class="biae__product-page-grid">
                  {%- endif -%}

                  {%- render 'bridal-in-action-product-card', block: block -%}

                  {%- assign rendered_compact_product_count = rendered_compact_product_count | plus: 1 -%}
                  {%- assign close_compact_product_page = rendered_compact_product_count | modulo: 2 -%}
                  {%- if close_compact_product_page == 0 or rendered_compact_product_count == product_count -%}
                    </div>
                    </li>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </ul>

            {%- if show_compact_product_slider -%}
              <div class="slider-buttons biae__product-slider-buttons no-js-hidden large-up-hide">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>

                <div class="slider-counter caption visually-hidden">
                  <span class="slider-counter--current">1</span>
                  <span aria-hidden="true"> / </span>
                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                  <span class="slider-counter--total">{{ compact_product_page_count }}</span>
                </div>

                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>
              </div>
            {%- endif -%}
          </slider-component>

          <slider-component class="biae__product-slider biae__product-slider--desktop small-hide medium-hide">
            <ul
              id="Slider-{{ section.id }}-products-desktop"
              class="biae__product-pages biae__product-pages--desktop{% if show_product_slider %} slider slider--everywhere{% endif %}"
              role="list"
              aria-label="{{ section.settings.product_heading | default: 'Bridal Hair Essentials' | escape }}"
            >
              {%- assign rendered_product_count = 0 -%}
              {%- for block in section.blocks -%}
                {%- if block.type == 'product_card' -%}
                  {%- assign product_modulo = rendered_product_count | modulo: 4 -%}
                  {%- if product_modulo == 0 -%}
                    <li
                      id="Slide-{{ section.id }}-products-desktop-{{ rendered_product_count | divided_by: 4 | floor | plus: 1 }}"
                      class="biae__product-page custom__slide{% if show_product_slider %} slider__slide{% endif %}"
                    >
                      <div class="biae__product-page-grid">
                  {%- endif -%}

                  {%- render 'bridal-in-action-product-card', block: block -%}

                  {%- assign rendered_product_count = rendered_product_count | plus: 1 -%}
                  {%- assign close_product_page = rendered_product_count | modulo: 4 -%}
                  {%- if close_product_page == 0 or rendered_product_count == product_count -%}
                    </div>
                    </li>
                  {%- endif -%}
                {%- endif -%}
              {%- endfor -%}
            </ul>

            {%- if show_product_slider -%}
              <div class="slider-buttons biae__product-slider-buttons no-js-hidden small-hide medium-hide">
                <button
                  type="button"
                  class="slider-button slider-button--prev"
                  name="previous"
                  aria-label="{{ 'general.slider.previous_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>

                <div class="slider-counter caption visually-hidden">
                  <span class="slider-counter--current">1</span>
                  <span aria-hidden="true"> / </span>
                  <span class="visually-hidden">{{ 'general.slider.of' | t }}</span>
                  <span class="slider-counter--total">{{ product_page_count }}</span>
                </div>

                <button
                  type="button"
                  class="slider-button slider-button--next"
                  name="next"
                  aria-label="{{ 'general.slider.next_slide' | t }}"
                >
                  {%- render 'icon-caret' -%}
                </button>
              </div>
            {%- endif -%}
          </slider-component>
        {%- else -%}
          <div class="biae__empty-state">Add product blocks to populate this panel.</div>
        {%- endif -%}
      </div>
    </section>
  </div>
</div>

{% schema %}
{
  "name": "Bridal In Action",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "video_heading",
      "label": "Video panel heading",
      "default": "In Action"
    },
    {
      "type": "textarea",
      "id": "video_intro",
      "label": "Video panel intro text"
    },
    {
      "type": "text",
      "id": "product_heading",
      "label": "Product panel heading",
      "default": "Bridal Hair Essentials"
    },
    {
      "type": "textarea",
      "id": "product_intro",
      "label": "Product panel intro text"
    },
    {
      "type": "text",
      "id": "social_link_label",
      "label": "Social link label",
      "default": "Find us on Socials"
    },
    {
      "type": "url",
      "id": "social_link",
      "label": "Social link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "video_card",
      "name": "Video card",
      "limit": 12,
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify-hosted video"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "accept": ["youtube", "vimeo"],
          "label": "External video URL",
          "info": "Used when no Shopify-hosted video is selected."
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Poster image"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Top-right tag",
          "default": "Bridal"
        },
        {
          "type": "text",
          "id": "handle",
          "label": "Handle or creator",
          "default": "@cliphairlimited"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Soft bridal volume finished with our clip-ins."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Linked product"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Override product thumbnail"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "CTA label",
          "default": "Shop Now"
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Product card",
      "limit": 12,
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "image_picker",
          "id": "override_image",
          "label": "Override image"
        },
        {
          "type": "text",
          "id": "override_title",
          "label": "Override title"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bridal In Action",
      "blocks": [
        { "type": "video_card" },
        { "type": "video_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
