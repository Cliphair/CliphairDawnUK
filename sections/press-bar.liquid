{{ 'section-press-bar.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  #PressBar-{{ section.id }} {
    --press-bar-duration: {{ section.settings.scroll_duration }}s;
  }
  #PressBar-{{ section.id }} .press-bar__logo {
    height: {{ section.settings.logo_height | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width:990px) {
    #PressBar-{{ section.id }} .press-bar__logo {
      height: {{ section.settings.logo_height }}px;
    }
  }
{%- endstyle -%}

<div
  class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  id="PressBar-{{ section.id }}"
>
  <div class="page-width press-bar">
    {%- if section.settings.label != blank -%}
      <h2 class="press-bar__label">{{ section.settings.label }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="press-bar__marquee"
        role="region"
        aria-label="{{ section.settings.label | default: 'Press features' | escape }}"
      >
        <ul class="press-bar__track" role="list">
          {%- for block in section.blocks -%}
            <li class="press-bar__item" {{ block.shopify_attributes }}>
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}">
              {%- endif -%}
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag:
                    loading: 'eager',
                    widths: '100, 150, 200, 300, 400',
                    sizes: '150px',
                    class: 'press-bar__logo',
                    alt: block.settings.image.alt
                  | escape
                }}
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        <ul class="press-bar__track" role="list" aria-hidden="true">
          {%- for block in section.blocks -%}
            <li class="press-bar__item">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" tabindex="-1">
              {%- endif -%}
              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 400
                  | image_tag:
                    loading: 'eager',
                    widths: '100, 150, 200, 300, 400',
                    sizes: '150px',
                    class: 'press-bar__logo',
                    alt: ''
                }}
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Press Bar",
  "tag": "section",
  "class": "section section-press-bar",
  "max_blocks": 12,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "label",
      "label": "Label",
      "default": "Our features..."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Logo height",
      "default": 40
    },
    {
      "type": "range",
      "id": "scroll_duration",
      "min": 5,
      "max": 60,
      "step": 5,
      "unit": "sec",
      "label": "Scroll speed",
      "default": 35
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Optional"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Press Bar",
      "blocks": [{ "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }]
    }
  ]
}
{% endschema %}
