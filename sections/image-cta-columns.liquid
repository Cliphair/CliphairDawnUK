{{ 'section-image-cta-columns.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="image-cta-columns color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- if section.blocks.size > 0 -%}
    <ul
      class="image-cta-columns__list"
      role="list"
    >
      {%- for block in section.blocks -%}
        <li class="image-cta-columns__item" {{ block.shopify_attributes }}>
          <div class="image-cta-card">
            {%- comment -%} Background image {%- endcomment -%}
            <div class="image-cta-card__media" aria-hidden="true">
              {%- if block.settings.image != blank -%}
                {%- liquid
                  assign mobile_img = block.settings.image
                  assign desktop_img = block.settings.image_desktop
                  assign img_height = mobile_img.width | divided_by: mobile_img.aspect_ratio | round
                -%}
                <picture>
                  <source
                    media="(max-width: 749px)"
                    srcset="
                      {{ mobile_img | image_url: width: 375 }} 375w,
                      {{ mobile_img | image_url: width: 550 }} 550w,
                      {{ mobile_img | image_url: width: 750 }} 750w
                    "
                    sizes="50vw"
                  >
                  {%- if desktop_img != blank -%}
                    <source
                      media="(min-width: 750px)"
                      srcset="
                        {{ desktop_img | image_url: width: 750 }} 750w,
                        {{ desktop_img | image_url: width: 1100 }} 1100w,
                        {{ desktop_img | image_url: width: 1500 }} 1500w
                      "
                      sizes="50vw"
                    >
                  {%- endif -%}
                  <img
                    src="{{ mobile_img | image_url: width: 750 }}"
                    loading="lazy"
                    alt="{{ mobile_img.alt | escape }}"
                    width="{{ mobile_img.width }}"
                    height="{{ img_height }}"
                    class="image-cta-card__img"
                  >
                </picture>
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- comment -%} Overlaid content {%- endcomment -%}
            <div class="image-cta-card__content">
              <div class="image-cta-card__body">
                {%- if block.settings.heading != blank -%}
                  <p class="image-cta-card__heading">{{ block.settings.heading }}</p>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="image-cta-card__text">{{ block.settings.text }}</p>
                {%- endif -%}
              </div>
              {%- if block.settings.button_label != blank -%}
                <a
                  class="button image-cta-card__btn"
                  {% if block.settings.button_link != blank %}
                    href="{{ block.settings.button_link }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                >
                  {{- block.settings.button_label | escape -}}
                </a>
              {%- endif -%}
            </div>
          </div>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Image CTA columns",
  "class": "section section-image-cta-columns",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "background-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background image (mobile / default)"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Background image (desktop, optional)",
          "info": "If left blank, the mobile image is used on all screen sizes."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Colour Match"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Description",
          "default": "Find your perfect shade, matched by our hair experts"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "default": "Match Me"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image CTA columns",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "heading": "Colour Match",
            "text": "Find your perfect shade, matched by our hair experts",
            "button_label": "Match Me"
          }
        },
        {
          "type": "card",
          "settings": {
            "heading": "Quiz",
            "text": "New to extensions? We'll walk you through it in 30 seconds",
            "button_label": "Take Quiz"
          }
        }
      ]
    }
  ]
}
{% endschema %}
