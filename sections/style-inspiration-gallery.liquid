{{ 'section-style-inspiration-gallery.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slider-custom.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign section_anchor_id = section.settings.anchor_id | handleize

  if section_anchor_id == blank
    assign section_anchor_id = 'style-inspiration-gallery-' | append: section.id
  endif
-%}

{%- style -%}
  #{{ section_anchor_id }} {
    scroll-margin-top: calc(var(--header-height, 0px) + 2rem);
  }
{%- endstyle -%}

<style-inspiration-gallery
  id="{{ section_anchor_id }}"
  class="section-style-inspiration-gallery color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding"
  data-anchor-id="{{ section_anchor_id }}"
  data-filter-query-param="style_filter"
  data-section-id="{{ section.id }}"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="sig-heading h2">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- comment -%} Filter tabs {%- endcomment -%}
    <div class="sig-filters" role="tablist" aria-label="Filter styles">
      <button class="sig-filter-btn" role="tab" aria-selected="true" data-filter="all">All</button>
      <span class="sig-filter-sep" aria-hidden="true">|</span>
      <button class="sig-filter-btn" role="tab" aria-selected="false" data-filter="hair up">Hair Up</button>
      <span class="sig-filter-sep" aria-hidden="true">|</span>
      <button class="sig-filter-btn" role="tab" aria-selected="false" data-filter="hair down">Hair Down</button>
      <span class="sig-filter-sep" aria-hidden="true">|</span>
      <button class="sig-filter-btn" role="tab" aria-selected="false" data-filter="half up half down">
        Half Up Half Down
      </button>
      <span class="sig-filter-sep" aria-hidden="true">|</span>
      <button class="sig-filter-btn" role="tab" aria-selected="false" data-filter="braids">Braids</button>
    </div>

    <div class="sig-layout">
      {%- comment -%} â”€â”€ Left column: gallery slider â”€â”€ {%- endcomment -%}
      <div class="sig-layout__gallery">
        {%- comment -%} Loading skeleton â€” visible until JS renders columns {%- endcomment -%}
        <div class="sig-loading" aria-hidden="true">
          <div class="sig-skeleton-column sig-skeleton-column--stack">
            <div class="sig-skeleton-item"></div>
            <div class="sig-skeleton-item"></div>
          </div>
          <div class="sig-skeleton-column sig-skeleton-column--stack">
            <div class="sig-skeleton-item"></div>
            <div class="sig-skeleton-item"></div>
          </div>
          <div class="sig-skeleton-column sig-skeleton-column--tall">
            <div class="sig-skeleton-item"></div>
          </div>
          <div class="sig-skeleton-column sig-skeleton-column--stack">
            <div class="sig-skeleton-item"></div>
            <div class="sig-skeleton-item"></div>
          </div>
          <div class="sig-skeleton-column sig-skeleton-column--stack">
            <div class="sig-skeleton-item"></div>
            <div class="sig-skeleton-item"></div>
          </div>
          <div class="sig-skeleton-column sig-skeleton-column--tall">
            <div class="sig-skeleton-item"></div>
          </div>
        </div>

        <slider-component-custom
          id="SigSlider-{{ section.id }}"
          class="sig-slider-component"
          data-visual="dots"
        >
          <ul
            id="Slider-{{ section.id }}"
            class="sig-grid slider"
            role="list"
            aria-label="{{ section.settings.heading | default: 'Style inspiration gallery' | escape }}"
          >
            {%- comment -%} Groups rendered by style-inspiration-gallery.js {%- endcomment -%}
          </ul>

          <div class="slider-buttons sig-slider-buttons no-js-hidden">
            <button
              type="button"
              class="slider-button slider-button--prev"
              name="previous"
              aria-label="{{ 'general.slider.previous_slide' | t }}"
            >
              {%- render 'icon-caret' -%}
            </button>
            <button
              type="button"
              class="slider-button slider-button--next"
              name="next"
              aria-label="{{ 'general.slider.next_slide' | t }}"
            >
              {%- render 'icon-caret' -%}
            </button>
          </div>

          <div class="sig-scrollbar" aria-hidden="true">
            <div class="sig-scrollbar__track">
              <button type="button" class="sig-scrollbar__thumb" tabindex="-1">
                <span class="visually-hidden">Gallery scrollbar</span>
              </button>
            </div>
          </div>
        </slider-component-custom>

        <p class="sig-empty" hidden>No styles found for this filter.</p>
      </div>

      {%- comment -%} â”€â”€ Right column: info panel â”€â”€ {%- endcomment -%}
      <div class="sig-layout__panel">
        <div
          class="sig-panel-placeholder"
          id="SigPanelPlaceholder-{{ section.id }}"
          hidden
          role="status"
          aria-live="polite"
          aria-atomic="true"
          aria-hidden="true"
        >
          <div class="sig-panel-placeholder__card">
            <p class="sig-panel-placeholder__eyebrow">Choose a style</p>
            <h3 class="sig-panel-placeholder__heading h4">Select a filter to see curated details</h3>
            <p class="sig-panel-placeholder__text">
              Pick Hair Up, Hair Down, Half Up Half Down or Braids to load the matching product, review and editorial
              guidance.
            </p>
            <div class="sig-panel-placeholder__media">
              <div class="sig-panel-placeholder__block sig-panel-placeholder__block--large"></div>
              <div class="sig-panel-placeholder__block sig-panel-placeholder__block--large"></div>
            </div>
            <div class="sig-panel-placeholder__footer">
              <div class="sig-panel-placeholder__block sig-panel-placeholder__block--thumb"></div>
              <div class="sig-panel-placeholder__copy">
                <div class="sig-panel-placeholder__block sig-panel-placeholder__block--line"></div>
                <div
                  class="sig-panel-placeholder__block sig-panel-placeholder__block--line sig-panel-placeholder__block--line-short"
                ></div>
              </div>
            </div>
          </div>
        </div>

        <div
          class="sig-panel"
          id="SigPanel-{{ section.id }}"
          hidden
          aria-live="polite"
          aria-atomic="true"
        >
          <div class="sig-panel__card">
            <div class="sig-panel__card-body">
              <h3 class="sig-panel__heading h4"></h3>
              <p class="sig-panel__editorial-text"></p>
              <div class="sig-panel__images">
                <div class="sig-panel__lifestyle-image media"></div>
                <div class="sig-panel__product-image media"></div>
              </div>
            </div>
            <div class="sig-panel__footer">
              <div class="sig-panel__footer-thumb media"></div>
              <div class="sig-panel__footer-info">
                <span class="sig-panel__product-title"></span>
              </div>
              <a class="sig-panel__cta button" href="#">Shop Now</a>
            </div>
            <div class="sig-panel__review">
              <div class="sig-panel__review-header">
                <span class="sig-panel__review-author h5"></span>
                <div class="sig-panel__stars" role="img" aria-label="5 out of 5 stars"></div>
              </div>
              <p class="sig-panel__review-text"></p>
              <button type="button" class="sig-panel__review-toggle link" hidden>Read more</button>
            </div>
          </div>

          <p class="sig-panel__indicator" hidden>
            <span class="sig-panel__indicator-current">1</span>
            <span aria-hidden="true"> / </span>
            <span class="sig-panel__indicator-total"></span>
          </p>
        </div>
      </div>
    </div>
  </div>

