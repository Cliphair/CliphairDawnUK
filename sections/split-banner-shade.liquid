{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-slider-custom.css' | asset_url | stylesheet_tag }}
{{ 'component-hair-goal-card.css' | asset_url | stylesheet_tag }}
{{ 'section-split-banner-shade.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}
{% if customer %}{{ customer.metafields.yotpo.loyalty_opt_in_source }}{% endif %}
<div class="section-{{ section.id }}-padding">
  <div class="split-banner-shade__outer">
    <div class="split-banner-shade__grid page-width" style="padding-right:0; padding-left:0;">
      {%- assign prioritise_first_image = section.settings.prioritise_lcp -%}
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'shade_slider' -%}
            {%- liquid
              assign menu = linklists[block.settings.menu]
              assign shade_count = 0
              for link in menu.links
                if link.type == 'collection_link'
                  assign shade_count = shade_count | plus: 1
                endif
              endfor
              assign show_controls = false
              if shade_count > 4
                assign show_controls = true
              endif
              assign image_ratio = block.settings.image_ratio | default: 'portrait'
              assign image_sizes = '(min-width: 990px) 145px, calc((100vw - 6rem) / 4)'
            -%}
            <div
              class=" page-width split-banner-shade__column split-banner-shade__column--shades color-{{ block.settings.color_scheme }} gradient"
              {{ block.shopify_attributes }}
            >
              {%- unless block.settings.heading == blank -%}
                <div class="split-banner-shade__heading-wrapper">
                  <h2 class="split-banner-shade__heading">{{ block.settings.heading | escape }}</h2>
                </div>
              {%- endunless -%}

              {%- if shade_count > 0 -%}
                <slider-component-custom
                  id="shade-slider-{{ section.id }}"
                  class="split-banner-shade__slider"
                  data-visual="dots"
                >
                  <ul
                    id="Slider-{{ section.id }}"
                    class="split-banner-shade__shade-list slider slider--everywhere"
                    role="list"
                    aria-label="{{ block.settings.heading | strip_html | escape }}"
                  >
                    {%- assign rendered_shades = 0 -%}
                    {%- assign slide_index = 0 -%}
                    {%- for link in menu.links -%}
                      {%- if link.type == 'collection_link' -%}
                        {%- liquid
                          assign col = link.object
                          assign loading_attr = 'lazy'
                          assign fetchpriority_attr = 'auto'
                          if prioritise_first_image
                            assign loading_attr = 'eager'
                            assign fetchpriority_attr = 'high'
                            assign prioritise_first_image = false
                          endif
                          assign rendered_shades = rendered_shades | plus: 1
                          assign slide_slot = rendered_shades | modulo: 4
                          if slide_slot == 1
                            assign slide_index = slide_index | plus: 1
                          endif
                        -%}
                        {%- if slide_slot == 1 -%}
                          <li
                            id="Slide-{{ section.id }}-{{ slide_index }}"
                            class="split-banner-shade__shade-item custom__slide slider__slide"
                          >
                            <div
                              class="split-banner-shade__shade-grid"
                              role="group"
                              aria-label="Shade slide {{ slide_index }}"
                            >
                        {%- endif -%}
                        <div class="split-banner-shade__shade-card hair-goal-card hair-goal-card--carousel">
                          <a href="{{ link.url }}" class="hair-goal-card__link">
                            <div class="hair-goal-card__media hair-goal-card__media--{{ image_ratio }}">
                              {%- if col.featured_image != blank -%}
                                {{
                                  col.featured_image
                                  | image_url: width: 900
                                  | image_tag:
                                    loading: loading_attr,
                                    fetchpriority: fetchpriority_attr,
                                    widths: '120, 180, 240, 320',
                                    sizes: image_sizes,
                                    class: 'hair-goal-card__image',
                                    alt: col.title
                                }}
                              {%- else -%}
                                {{ 'image' | placeholder_svg_tag: 'hair-goal-card__image placeholder' }}
                              {%- endif -%}
                            </div>
                            <div class="hair-goal-card__text">
                              <span class="hair-goal-card__name">{{ link.title | escape }}</span>
                            </div>
                          </a>
                        </div>
                        {%- if slide_slot == 0 or rendered_shades == shade_count -%}
                          </div>
                          </li>
                        {%- endif -%}
                      {%- endif -%}
                    {%- endfor -%}
                  </ul>

                  {%- if show_controls -%}
                    <div class="slider-buttons split-banner-shade__slider-footer no-js-hidden">
                      <button
                        type="button"
                        class="slider-button slider-button--prev"
                        name="previous"
                        aria-label="{{ 'general.slider.previous_slide' | t }}"
                      >
                        {%- render 'icon-caret' -%}
                      </button>
                      <div class="slideshow__control-wrapper slider-counter slider-counter--dots"></div>
                      <button
                        type="button"
                        class="slider-button slider-button--next"
                        name="next"
                        aria-label="{{ 'general.slider.next_slide' | t }}"
                      >
                        {%- render 'icon-caret' -%}
                      </button>
                    </div>
                  {%- endif -%}
                </slider-component-custom>
              {%- else -%}
                <p class="split-banner-shade__empty">No shades found. Add collection links to the selected menu.</p>
              {%- endif -%}
            </div>

          {%- when 'banner' -%}
            {%- liquid
              assign banner_image = block.settings.image_desktop
              assign banner_image_mobile = block.settings.image_mobile | default: banner_image
              if banner_image == blank
                assign banner_image = banner_image_mobile
              endif
              assign banner_render_image = banner_image_mobile | default: banner_image
              assign banner_alt = banner_render_image.alt | default: ''
              assign banner_loading = 'lazy'
              assign banner_fetchpriority = 'auto'
              if prioritise_first_image and banner_render_image != blank
                assign banner_loading = 'eager'
                assign banner_fetchpriority = 'high'
                assign prioritise_first_image = false
              endif
              if banner_render_image != blank
                assign banner_render_height = banner_render_image.width | divided_by: banner_render_image.aspect_ratio | round
              endif
              assign banner_mobile_aspect_ratio = banner_image_mobile.aspect_ratio | default: banner_render_image.aspect_ratio
              assign banner_desktop_aspect_ratio = banner_image.aspect_ratio | default: banner_render_image.aspect_ratio
            -%}
            <div
              class="split-banner-shade__column split-banner-shade__column--banner color-{{ block.settings.color_scheme }} gradient"
              {{ block.shopify_attributes }}
            >
              {%- unless block.settings.title == blank -%}
                <div class=" page-width split-banner-shade__heading-wrapper">
                  <h2 class="split-banner-shade__heading">{{ block.settings.title | escape }}</h2>
                </div>
              {%- endunless -%}
              <a
                href="{{ block.settings.url }}"
                class="split-banner-shade__banner-link"
                style="--split-banner-shade-aspect-ratio-mobile: {{ banner_mobile_aspect_ratio }}; --split-banner-shade-aspect-ratio-desktop: {{ banner_desktop_aspect_ratio }};"
              >
                {%- if banner_render_image != blank -%}
                  <picture class="split-banner-shade__banner-media">
                    {%- if banner_image_mobile != blank -%}
                      <source
                        media="(max-width: 749px)"
                        srcset="
                          {{ banner_image_mobile | image_url: width: 375 }} 375w,
                          {{ banner_image_mobile | image_url: width: 550 }} 550w,
                          {{ banner_image_mobile | image_url: width: 750 }} 750w,
                          {{ banner_image_mobile | image_url: width: 900 }} 900w
                        "
                        sizes="100vw"
                      >
                    {%- endif -%}
                    {%- if banner_image != blank -%}
                      <source
                        media="(min-width: 750px)"
                        srcset="
                          {{ banner_image | image_url: width: 750 }} 750w,
                          {{ banner_image | image_url: width: 1000 }} 1000w,
                          {{ banner_image | image_url: width: 1200 }} 1200w,
                          {{ banner_image | image_url: width: 1500 }} 1500w
                        "
                        sizes="(min-width: 990px) 50vw, 100vw"
                      >
                    {%- endif -%}
                    <img
                      class="split-banner-shade__banner-img"
                      src="{{ banner_render_image | image_url: width: 900 }}"
                      loading="{{ banner_loading }}"
                      fetchpriority="{{ banner_fetchpriority }}"
                      sizes="(min-width: 990px) 50vw, 100vw"
                      alt="{{ banner_alt | escape }}"
                      width="{{ banner_render_image.width }}"
                      height="{{ banner_render_height }}"
                    >
                  </picture>
                {%- endif -%}
                {%- unless block.settings.link_text == blank -%}
                  <span class="visually-hidden">{{ block.settings.link_text | escape }}</span>
                {%- endunless -%}
              </a>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split — Banner & Shades",
  "tag": "section",
  "class": "section section-split-banner-shade",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 2,
  "settings": [
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    },
    {
      "type": "checkbox",
      "id": "prioritise_lcp",
      "label": "Prioritise first image (LCP)",
      "info": "Enable only when this section is the first visible content on the page.",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "shade_slider",
      "name": "Shop by Shade",
      "limit": 1,
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Colour scheme",
          "default": "scheme-1"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Or shop by shade..."
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Shade menu",
          "info": "Create a navigation menu whose links all point to shade collections. Non-collection links are ignored.",
          "default": "main-menu"
        },
        {
          "type": "select",
          "id": "image_ratio",
          "label": "Image ratio",
          "options": [
            { "value": "portrait", "label": "Portrait (3:4)" },
            { "value": "square", "label": "Square (1:1)" },
            { "value": "landscape", "label": "Landscape (4:3)" }
          ],
          "default": "square"
        }
      ]
    },
    {
      "type": "banner",
      "name": "Banner",
      "limit": 1,
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Colour scheme",
          "default": "scheme-1"
        },
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Mobile image",
          "info": "Displayed on screens narrower than 750px. Falls back to desktop image if not set."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link description",
          "info": "Hidden from view but read by search engines and screen readers. Describe where this banner links to.",
          "default": "Shop our rewards programme"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split — Banner & Shade Slider",
      "blocks": [{ "type": "shade_slider" }, { "type": "banner" }]
    }
  ]
}
{% endschema %}
