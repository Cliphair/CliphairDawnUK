{%- comment -%}
  Renders the country picker for the localization form

  Accepts:
    - localPosition: pass in the position in which the form is coming up to create specific IDs
{%- endcomment -%}

{% liquid
  assign first_countries = 'United Kingdom;United States;Ireland;Canada;Australia' | split: ';'
%}

<div class="disclosure">
  <button
    type="button"
    class="disclosure__button localization-form__select localization-selector link link--text caption-large"
    aria-expanded="false"
    aria-controls="{{ localPosition }}List"
    aria-describedby="{{ localPosition }}Label"
  >
    <span>
      {{- localization.country.currency.iso_code }}
      {{ localization.country.currency.symbol }}
    </span>
    {% comment %}
      <span class="localization-form__flag">
        {{ localization.country | image_url: width: 30 | image_tag }}
      </span>
    {% endcomment %}
    {% render 'icon-caret' %}
  </button>
  <div class="disclosure__list-wrapper" hidden>
    <ul id="{{ localPosition }}List" role="list" class="disclosure__list list-unstyled">
      {% comment %}Best selling countires in order{% endcomment %}
      {% for country_name in first_countries %}
        {% assign country = localization.available_countries | where: 'name', country_name | first %}
        <li class="disclosure__item" tabindex="-1">
          <a
            class="link link--text disclosure__link caption-large focus-inset{% if country.iso_code == localization.country.iso_code %} disclosure__link--active{% endif %}"
            href="#"
            {% if country.iso_code == localization.country.iso_code %}
              aria-current="true"
            {% endif %}
            data-value="{{ country.iso_code }}"
          >
            <span class="localization-form__flag">
              {% if country_name == 'Ireland' %}
                <img src="{{ "euro-zone.svg" | asset_url }}" alt="Euro Zone" width="32" height="24" loading="lazy">
              {% else %}
                {{ country | image_url: width: 32 | image_tag: loading: 'lazy' }}
              {% endif %}
            </span>
            {% comment %} {{ country.name }} {% endcomment %}
            {{- country.currency.iso_code }}
            {{ country.currency.symbol }}
          </a>
        </li>
      {% endfor %}

      <li class="disclosure_break-line"></li>

<li class="disclosure__item" tabindex="-1">
  <button type="button" class="link link--text disclosure__link caption-large focus-inset js-load-all-countries">
    More countries
  </button>
</li>


    </ul>
<script type="application/json" id="{{ localPosition }}CountriesJson">
[
  {%- for country in localization.available_countries -%}
    {
      "name": {{ country.name | json }},
      "iso_code": {{ country.iso_code | json }},
      "currency_iso": {{ country.currency.iso_code | json }},
      "currency_symbol": {{ country.currency.symbol | json }},
      "flag": {{ country | image_url: width: 32 | json }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
</script>

  </div>
</div>
<input type="hidden" name="country_code" value="{{ localization.country.iso_code }}">


<script>
document.addEventListener('click', function(e) {
  var btn = e.target.closest('.js-load-all-countries');
  if (!btn) return;

  var wrapper = btn.closest('.disclosure__list-wrapper');
  var list = wrapper.querySelector('.disclosure__list');
  var jsonEl = wrapper.parentElement.querySelector('script[type="application/json"]');

  if (!jsonEl || list.dataset.loadedCountries === 'true') return;

  var countries = JSON.parse(jsonEl.textContent);

  countries.forEach(function(country) {
    if (list.querySelector('[data-value="' + country.iso_code + '"]')) return;

    var li = document.createElement('li');
    li.className = 'disclosure__item';
    li.setAttribute('tabindex', '-1');

    li.innerHTML =
      '<a class="link link--text disclosure__link caption-large focus-inset" href="#" data-value="' + country.iso_code + '">' +
        '<span class="localization-form__flag">' +
          '<img src="' + country.flag + '" alt="' + country.name + '" width="32" height="24" loading="lazy">' +
        '</span>' +
        country.currency_iso + ' ' + country.currency_symbol +
      '</a>';

    list.appendChild(li);
  });

  list.dataset.loadedCountries = 'true';
  btn.closest('li').remove();
});
</script>
